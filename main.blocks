e><next><block type="typescript_statement" id="bPly`=5BFUrC6PG)Hi%0"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="let result = &quot;&quot;" numlines="1" declaredvars="result"></mutation><next><block type="typescript_statement" id="dAf1khCW8,{6A~ufG063"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="class Level {" line1="    bgHue: number = null;" line2="    platformDistance: Array&lt;number&gt; = null;" line3="    platformWidth: Array&lt;number&gt; = null;" line4="    tileProbability: Array&lt;any&gt; = null;" line5="    itemCounts: Array&lt;any&gt; = null;" line6="" line7="    constructor(" line8="        platformDistance: Array&lt;number&gt;," line9="        platformWidth: Array&lt;number&gt;," line10="        tileProbability: Array&lt;any&gt;," line11="        itemCounts: Array&lt;any&gt;," line12="        bgHue: number = null" line13="    ) {" line14="        this.platformDistance = platformDistance;" line15="        this.platformWidth = platformWidth;" line16="        this.tileProbability = tileProbability;" line17="        this.bgHue = bgHue;" line18="        this.itemCounts = itemCounts;" line19="    }" line20="" line21="    generate() {" line22="        // Seed RNG with level id to get consistent generations" line23="        let rng = new Math.FastRandom(level * 1000);" line24="        // Waste RNG (seems to have distribution issues?)" line25="        for (let i = 0; i &lt; level * 2; i++)" line26="            rng.next();" line27="" line28="        // Redefine randint to use seeded rng" line29="        let randint = function (min: number, max: number) {" line30="            return Math.round(rng.randomRange(min, max));" line31="        }" line32="" line33="        let bgHue = this.bgHue;" line34="        console.log(bgHue)" line35="        if (bgHue == null) {" line36="            bgHue = (rng.next() / 0xFFFF) * 360;" line37="        }" line38="        console.log(bgHue)" line39="" line40="" line41="        let colorBG = color.HSL.fromHexValue(0x2F3169);" line42="        colorBG.hue = bgHue;" line43="        let colorStars = color.HSL.fromHexValue(0x6B5394);" line44="        colorStars.hue = bgHue;" line45="" line46="        color.setColor(8, colorBG.hexValue());" line47="        color.setColor(11, colorStars.hexValue());" line48="" line49="        tilemapCurrent = tilemap`level`;" line50="        tiles.setTilemap(tilemapCurrent);" line51="" line52="        function randomTile(tileProbability: Array&lt;any&gt;) {" line53="            let value = rng.randomRange(0, 100) / 100.0;" line54="            let total = 0;" line55="            for (let j = 0; j &lt; tileProbability.length - 1; j++) {" line56="                let probability = tileProbability[j].probability;" line57="                if (probability + total &gt;= value)" line58="                    return tileProbability[j].tile;" line59="                total += probability;" line60="            }" line61="            return tileProbability[tileProbability.length - 1].tile;" line62="        }" line63="" line64="        let y = tilemapCurrent.height - 6;" line65="        // Create platforms" line66="        // We leave a roughly square area around the zapfish" line67="        while (y &gt; tilemapCurrent.width) {" line68="            let x = randint(0, tilemapCurrent.width - 1);" line69="            let width = randint(this.platformWidth[0], this.platformWidth[1]);" line70="            let tile = randomTile(this.tileProbability);" line71="            for (let k = 0; k &lt; width; k++) {" line72="                x = (x + 1) % tilemapCurrent.width;" line73="                let tileLocation = tiles.getTileLocation(x, y);" line74="                tiles.setTileAt(tileLocation, tile);" line75="                tiles.setWallAt(tileLocation, true);" line76="            }" line77="            y -= randint(this.platformDistance[0], this.platformDistance[1]);" line78="        }" line79="" line80="        this.itemCounts.forEach(item =&gt; {" line81="            let count = item.count;" line82="            while (count &gt; 0) {" line83="                let tileLocation2 = tiles.getTileLocation(" line84="                    randint(2, 10)," line85="                    randint(tilemapCurrent.width, tilemapCurrent.height)" line86="                );" line87="                if (tiles.tileAtLocationIsWall(tileLocation2))" line88="                    continue;" line89="                tiles.setTileAt(tileLocation2, item.tile)" line90="                count -= 1;" line91="            }" line92="        });" line93="    }" line94="}" numlines="95"></mutation><next><block type="variables_set" id="FMsY;;c,t$O9gqKC^X.~"><field name="VAR" id="gLa]uZrIQ8KUe(BCmqX.">level</field><value name="VALUE"><shadow type="math_number" id="P;]|AX0UAIKX!+Z9XmcZ"><field name="NUM">1</field></shadow></value><next><block type="typescript_statement" id="3oIM3rmtPhf#(Yk63f/X"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="let levelDataFirst = new Level(" line1="    [4, 6]," line2="    [4, 6]," line3="    [{" line4="        tile: assets.tile`ground`," line5="        probability: 1" line6="    }]," line7="    []," line8="    238" line9=");" numlines="10" declaredvars="levelDataFirst"></mutation><next><block type="typescript_statement" id="fCa)4HGk@|ybv=}YR~+c"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="let levelData1 = new Level(" line1="    [4, 8]," line2="    [4, 6]," line3="    [{" line4="        tile: assets.tile`ground`," line5="        probability: 1" line6="    }]," line7="    [{" line8="        tile: assets.tile`blowfish`," line9="        count: 5" line10="    }]" line11=");" numlines="12" declaredvars="levelData1"></mutation><next><block type="typescript_statement" id="5`|/~$91wZ}UJ$LtEMgW"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="let levelData2 = new Level(" line1="    [4, 8]," line2="    [4, 5]," line3="    [{" line4="        tile: assets.tile`ground`," line5="        probability: 1" line6="    }]," line7="   